# LxzClaw Configuration

# Gateway
LXZ_GATEWAY_PORT=18789
LXZ_GATEWAY_HOST=127.0.0.1

# LLM Provider
LXZ_LLM_PROVIDER=anthropic
LXZ_ANTHROPIC_API_KEY=your-api-key-here
LXZ_MINIMAX_API_KEY=your-api-key-here
LXZ_OPENAI_API_KEY=your-api-key-here

# Model
LXZ_MODEL=claude-sonnet-4-20250514

# Paths
LXZ_HOME=~/.lxzclaw
LXZ_DATA_DIR=~/.lxzclaw/data

# Features
LXZ_SESSION_DIR=~/.lxzclaw/sessions
LXZ_SKILLS_DIR=~/.lxzclaw/skills

# Logging
LXZ_LOG_LEVEL=info
LXZ_LOG_FILE=~/.lxzclaw/logs/lxzclaw.log
