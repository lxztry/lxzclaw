# LxzClaw Configuration

# Gateway
LXZ_GATEWAY_PORT=18789
LXZ_GATEWAY_HOST=127.0.0.1
LXZ_AUTH_TOKEN=your-auth-token  # 可选，用于API认证

# LLM Provider (可选: anthropic, minimax, glm, openrouter, openai)
LXZ_LLM_PROVIDER=glm

# GLM 配置
LXZ_GLM_API_KEY=your-glm-api-key
LXZ_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# MiniMax 配置 (可选)
# LXZ_LLM_PROVIDER=minimax
# LXZ_MINIMAX_API_KEY=your-minimax-api-key
# LXZ_MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# OpenRouter 配置 (可选)
# LXZ_LLM_PROVIDER=openrouter
# LXZ_OPENROUTER_API_KEY=your-openrouter-api-key

# Anthropic 配置 (可选)
# LXZ_LLM_PROVIDER=anthropic
# LXZ_ANTHROPIC_API_KEY=your-anthropic-api-key

# Model
LXZ_MODEL=glm-4-flash

# Paths
LXZ_HOME=~/.lxzclaw
LXZ_DATA_DIR=~/.lxzclaw/data
LXZ_SESSION_DIR=~/.lxzclaw/sessions
LXZ_SKILLS_DIR=~/.lxzclaw/skills

# Logging
LXZ_LOG_LEVEL=info
LXZ_LOG_FILE=~/.lxzclaw/logs/lxzclaw.log